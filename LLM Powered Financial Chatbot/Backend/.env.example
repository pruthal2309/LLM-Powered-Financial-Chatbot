# Server Configuration
PORT=8000

# Database Configuration
# Get your MongoDB connection string from https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/finchatbot?retryWrites=true&w=majority

# CORS Configuration (Frontend URL)
# Development: http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# Python Backend URL (for AI processing)
# Development: http://localhost:5000
# Production: https://your-python-api.com
PYTHON_SERVICE_URL=http://localhost:5000
